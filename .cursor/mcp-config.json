{
  "mcpServers": {
    "filesystem": {
      "command": "node",
      "args": [
        "-e",
        "console.log(JSON.stringify({version:'1.0',capabilities:{tools:{},resources:{},prompts:{}},serverInfo:{name:'filesystem',version:'1.0.0'}}))"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    }
  }
}
